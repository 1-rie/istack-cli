{
  "name": "istack-cli",
  "version": "1.2.0",
  "description": "iStack CLI — iOS AI Builder",
  "type": "module",
  "bin": {
    "istack": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "encrypt-skills": "bun run scripts/encrypt-skills.ts",
    "build": "bun run encrypt-skills && bun run scripts/build.ts",
    "checksum": "for f in dist/istack-*; do [ -f \"$f\" ] && shasum -a 256 \"$f\" > \"$f.sha256\"; done"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.0",
    "@google/generative-ai": "^0.17.0",
    "@inkjs/ui": "^2.0.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "conf": "^13.0.0",
    "ink": "^5.0.1",
    "ink-spinner": "^5.0.0",
    "jose": "^5.9.6",
    "openai": "^4.52.0",
    "react": "^18.3.0",
    "react-devtools-core": "^7.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "bun-types": "^1.1.0",
    "typescript": "^5.5.0"
  }
}
